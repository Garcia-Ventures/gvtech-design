{
  "name": "@gv-tech/design-system",
  "root": ".",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist", "{workspaceRoot}/dist-site"],
      "options": {
        "command": "bun run build",
        "cwd": "."
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run format:ci",
        "cwd": "."
      }
    },
    "format:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run format",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run lint",
        "cwd": "."
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run lint:fix",
        "cwd": "."
      }
    },
    "nx-release-publish": {
      "dependsOn": [
        "build"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --provenance --access public",
        "cwd": "."
      }
    }
  }
}
