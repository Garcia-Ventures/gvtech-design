# Primary Plausible env vars (preferred)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=garciaericn.com
NEXT_PUBLIC_PLAUSIBLE_ENDPOINT=https://stats.garciaericn.com/api/event

# Optional compatibility fallback for Vite-only setups
VITE_PLAUSIBLE_DOMAIN=gvtech-design.pages.dev
VITE_PLAUSIBLE_ENDPOINT=https://stats.garciaericn.com/api/event

# Optional flag to disable analytics in any environment
NEXT_PUBLIC_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENABLED=true
# Set to true to log all analytics activity to the browser console
VITE_ANALYTICS_DEBUG=false
