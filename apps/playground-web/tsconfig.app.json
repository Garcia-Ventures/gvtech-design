{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@gv-tech/design-tokens": ["../../packages/design-tokens/src"],
      "@gv-tech/ui-core": ["../../packages/ui-core/src"],
      "@gv-tech/ui-web": ["../../packages/ui-web/src"],
      "@gv-tech/ui-native": ["../../packages/ui-native/src"]
    }
  },
  "include": ["src", "../../packages/ui-web/src"]
}
